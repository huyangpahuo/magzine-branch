doctype html
html(lang=config.language)
  head
    meta(charset='UTF-8')
    title= (page.title || '关于我') + ' | ' + config.title
    link(rel='stylesheet', href=url_for('/css/about.css'))
    link(rel='stylesheet', href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css')

  body
    main.about-page
      #background-shapes

      .about-container
        //- 头部 
        .about-header
          .about-avatar
            img(src=url_for(theme.author_card && theme.author_card.avatar ? theme.author_card.avatar : '/img/avatar.png'), alt="Avatar")
          h1.about-name= theme.author_card && theme.author_card.name ? theme.author_card.name : 'Your Name'
          p.about-bio= theme.author_card && theme.author_card.bio ? theme.author_card.bio : 'Your Bio'

        //- 卡片展示区 (保持不变)
        .interests-showcase
          if site.data.about && site.data.about.cards
            each card in site.data.about.cards
              - var cardClass = 'interest-card'
              - if (card.layout) cardClass += ' card-' + card.layout
              - if (card.size) cardClass += ' card-' + card.size
              
              a(class=cardClass, href=card.link || '#', target="_blank")
                - var bgStyle = card.image ? `background-image: url(${url_for(card.image)});` : `background: ${card.background};`
                .card-bg(style=`${bgStyle} background-size: cover; background-position: center;`)
                
                .card-content
                  h3.card-title= card.title
                  .card-description
                    p= card.description
                  .card-icon
                    i(class=card.icon)
                  .card-hover-content
                    p= card.details
          else
             p(style="text-align:center; opacity:0.6") 暂无数据
        //- 详情区域
        .about-details
          
          //- 1. 关于我
          //- 1. 关于我 (自适应贴纸布局)
          .about-section
            h2 关于我
            .intro-card-wrapper
              //- 背景图片层
              .intro-banner-bg
                img(src=url_for('/images/1.jpg'), alt="Banner", onerror="this.style.display='none'")
                .banner-overlay
    
              //- 内容层：现在由它来撑开高度
              .profile-info-content
                .profile-item(data-label="称呼") 胡杨怕火
                .profile-item(data-label="年龄") 19岁
                .profile-item(data-label="大学") 河南师范大学软件工程
                .profile-item(data-label="爱好") 做游戏和绘画
                .profile-item(data-label="擅长") 吃饱睡睡饱吃
                .profile-item(data-label="身份") 二次元爱好者

          //- 2. 我的技能点
          .about-section
            h2 我的技能点
            .interest-cloud
              span.tag 摄影和剪辑
              span.tag 像素画和二次元绘画
              span.tag Logo和矢量图设计
              span.tag 各种计算机语言
              span.tag Blender建模
              span.tag Linux
              span.tag 计算机图形学
              span.tag 微信小程序
              span.tag AI
              span.tag 游戏制作
              span.tag 写小说
              span.tag 我的世界模组制作
              span.tag 英语
              span.tag 日语
              span.tag 前端和数据库
              span.tag 安卓应用制作

          //- 3. 碎碎念
          .about-section
            h2 碎碎念
            .bio-content(style="white-space: pre-wrap;")
              != page.content

          //- 4. 联系方式
          .about-section
            h2 联系方式
            .contact-info
              a.contact-item(href="mailto:3930088367@qq.com")
                i.fas.fa-envelope
                div
                  .contact-label 邮箱
                  .contact-value 3930088367@qq.com
              a.contact-item(href="https://github.com/huyangpahuo")
                i.fab.fa-github
                div
                  .contact-label GitHub
                  .contact-value huyangpahuo
              a.contact-item(href="https://space.bilibili.com/3546621941910044")
                i.fas.fa-tv
                div
                  .contact-label 哔哩哔哩
                  .contact-value 胡杨怕火

    script.
      document.addEventListener('DOMContentLoaded', function() {
        // === 背景几何图形漫游 ===
        const shapeContainer = document.getElementById('background-shapes');
        if(shapeContainer) {
          shapeContainer.innerHTML = '';
          const shapeCount = 15;
          const shapes = [];

          for (let i = 0; i < shapeCount; i++) {
            const shape = document.createElement('div');
            shape.classList.add('shape');
            const type = Math.random();
            if (type < 0.33) shape.classList.add('shape-circle');
            else if (type < 0.66) shape.classList.add('shape-square');
            else shape.classList.add('shape-triangle');

            const size = Math.random() * 70 + 30;
            shape.style.width = `${size}px`;
            shape.style.height = `${size}px`;
            shape.style.opacity = Math.random() * 0.25 + 0.05;

            let x = Math.random() * window.innerWidth;
            let y = Math.random() * window.innerHeight;
            let vx = (Math.random() - 0.5) * 1.5;
            let vy = (Math.random() - 0.5) * 1.5;
            let r = Math.random() * 360;
            let vr = (Math.random() - 0.5) * 0.5;

            shapeContainer.appendChild(shape);
            shapes.push({ el: shape, x, y, vx, vy, r, vr });
          }

          function animateShapes() {
            const w = window.innerWidth;
            const h = window.innerHeight;
            shapes.forEach(s => {
              s.x += s.vx; s.y += s.vy; s.r += s.vr;
              if (s.x <= -50 || s.x >= w + 50) s.vx *= -1;
              if (s.y <= -50 || s.y >= h + 50) s.vy *= -1;
              s.el.style.transform = `translate3d(${s.x}px, ${s.y}px, 0) rotate(${s.r}deg)`;
            });
            requestAnimationFrame(animateShapes);
          }
          animateShapes();
        }

        // === 卡片 3D ===
        const cards = document.querySelectorAll('.interest-card');
        cards.forEach(card => {
          card.addEventListener('mousemove', function(e) {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            let rotateY = x / 40; 
            let rotateX = -y / 40;
            card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02) translateY(-10px)`;
          });
          card.addEventListener('mouseleave', function() {
            card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1) translateY(0)';
          });
        });
      });